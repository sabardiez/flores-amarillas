<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Floricienta 🌻</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: #1a0800;
      overflow: hidden;
      font-family: monospace;
    }

    #scene {
      display: block;
      width: 100%;
      position: absolute;
      top: 0;
      left: 0;
    }

    #audioBar {
      position: fixed;
      top: 16px;
      left: 50%;
      transform: translateX(-50%);
      background: rgba(60, 20, 0, 0.75);
      border-radius: 40px;
      padding: 8px 20px;
      display: flex;
      align-items: center;
      gap: 12px;
      z-index: 100;
      border: 1px solid rgba(255, 180, 60, 0.5);
      backdrop-filter: blur(4px);
      white-space: nowrap;
    }

    #playBtn {
      width: 34px;
      height: 34px;
      border-radius: 50%;
      border: 2px solid #ffb83a;
      background: rgba(255, 184, 58, 0.15);
      color: #ffb83a;
      font-size: 14px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.2s;
    }

    #playBtn:hover {
      background: rgba(255, 184, 58, 0.35);
    }

    #audioLabel {
      font-size: 11px;
      color: #ffb83a;
      letter-spacing: 1px;
    }

    #nowPlaying {
      font-size: 10px;
      color: rgba(255, 184, 58, 0.6);
      max-width: 120px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    #fileInput {
      display: none;
    }

    #uploadBtn {
      font-size: 10px;
      color: rgba(255, 184, 58, 0.7);
      cursor: pointer;
      border: 1px solid rgba(255, 184, 58, 0.3);
      border-radius: 20px;
      padding: 3px 10px;
      background: transparent;
      transition: all 0.2s;
    }

    #uploadBtn:hover {
      background: rgba(255, 184, 58, 0.1);
      color: #ffb83a;
    }

    #volumeSlider {
      width: 60px;
      accent-color: #ffb83a;
      cursor: pointer;
    }
  </style>
</head>

<body>

  <canvas id="scene"></canvas>

  <div id="audioBar">
    <button id="playBtn">▶</button>
    <div style="display:flex;flex-direction:column;gap:2px">
      <span id="audioLabel">♪ FLORICIENTA</span>
      <span id="nowPlaying">dale play</span>
    </div>
    <input type="range" id="volumeSlider" min="0" max="1" step="0.05" value="0.7">
    <button id="uploadBtn" onclick="document.getElementById('fileInput').click()">+ canción</button>
    <input type="file" id="fileInput" accept="audio/*">
  </div>

  <audio id="audio" loop src="flores-amarillas.mp3"></audio>

  <script>
    const canvas = document.getElementById('scene');
    const ctx = canvas.getContext('2d');

    function resize() {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    }
    resize();
    window.addEventListener('resize', () => { bgCache = null; resize(); initScene(); });

    const W = () => canvas.width;
    const H = () => canvas.height;
    const groundY = () => Math.floor(H() * 0.70);

    function hexToRgb(hex) {
      return [parseInt(hex.slice(1, 3), 16), parseInt(hex.slice(3, 5), 16), parseInt(hex.slice(5, 7), 16)];
    }

    // Warm sunset palette - golden hour
    const SKY = ['#3d1000', '#7a2200', '#c44a00', '#e87820', '#f5a830', '#ffd060'];

    let bgCache = null, bgW = 0, bgH = 0;

    function renderBg() {
      if (bgCache && bgW === W() && bgH === H()) return;
      bgW = W(); bgH = H();
      const off = document.createElement('canvas');
      off.width = bgW; off.height = bgH;
      const oc = off.getContext('2d');
      const pz = 4;

      // Sky gradient warm
      const rows = Math.ceil(bgH * 0.70 / pz);
      const cols = Math.ceil(bgW / pz);
      for (let r = 0; r < rows; r++) {
        const t = r / rows;
        const idx = Math.min(4, Math.floor(t * 5));
        const frac = (t * 5) - idx;
        const c1 = hexToRgb(SKY[idx]);
        const c2 = hexToRgb(SKY[Math.min(5, idx + 1)]);
        const cr = Math.round(c1[0] + (c2[0] - c1[0]) * frac);
        const cg = Math.round(c1[1] + (c2[1] - c1[1]) * frac);
        const cb = Math.round(c1[2] + (c2[2] - c1[2]) * frac);
        for (let c = 0; c < cols; c++) {
          oc.fillStyle = `rgb(${cr},${cg},${cb})`;
          oc.fillRect(c * pz, r * pz, pz, pz);
        }
      }

      // Warm glowing horizon line
      for (let x = 0; x < bgW; x += pz) {
        oc.fillStyle = '#ffdd88';
        oc.globalAlpha = 0.18;
        oc.fillRect(x, groundY() - pz * 2, pz, pz * 4);
      }
      oc.globalAlpha = 1;

      // Ground - warm earth tones
      const gY = groundY();
      const gpz = 5;
      const glayers = [
        ['#5c3010', '#6a3818', '#784020'],
        ['#4a2808', '#583010', '#663818'],
        ['#3a1e04', '#48260c', '#562e14'],
      ];
      const grows = Math.ceil((bgH - gY) / gpz);
      const gcols = Math.ceil(bgW / gpz);
      for (let r = 0; r < grows; r++) {
        const pal = glayers[Math.min(r, glayers.length - 1)];
        for (let c = 0; c < gcols; c++) {
          oc.fillStyle = pal[Math.floor(Math.random() * 3)];
          oc.fillRect(c * gpz, gY + r * gpz, gpz, gpz);
        }
      }

      // Warm grass tips
      const grassC = ['#8bc34a', '#7cb342', '#9ccc65', '#6aaa3a'];
      for (let x = 0; x < bgW; x += gpz) {
        const gh = gpz * (2 + Math.floor(Math.random() * 3));
        oc.fillStyle = grassC[Math.floor(Math.random() * 4)];
        oc.fillRect(x, gY - gh, gpz, gh);
      }

      // Warm clouds
      const cloudDefs = [{ x: 0.12, y: 0.10 }, { x: 0.42, y: 0.06 }, { x: 0.75, y: 0.13 }];
      cloudDefs.forEach((cd, si) => {
        const cx = cd.x * bgW, cy = cd.y * bgH;
        const cpz = 4;
        [{ dx: 0, dy: 0, w: 48, h: 22 }, { dx: -22, dy: 9, w: 32, h: 16 }, { dx: 24, dy: 9, w: 32, h: 16 }, { dx: -6, dy: -11, w: 26, h: 14 }].forEach(b => {
          for (let dy = -b.h / 2; dy <= b.h / 2; dy += cpz) {
            for (let dx = -b.w / 2; dx <= b.w / 2; dx += cpz) {
              const nx = dx / b.w * 2, ny = dy / b.h * 2;
              if (nx * nx + ny * ny <= 1) {
                const br = (si * dx * dy) % 4 < 1;
                oc.fillStyle = br ? 'rgba(255,210,130,0.75)' : 'rgba(240,160,80,0.55)';
                oc.fillRect(Math.round((cx + b.dx + dx) / cpz) * cpz, Math.round((cy + b.dy + dy) / cpz) * cpz, cpz, cpz);
              }
            }
          }
        });
      });

      // Warm stars (few)
      for (let i = 0; i < 20; i++) {
        const sx = Math.floor(Math.random() * bgW / 4) * 4;
        const sy = Math.floor(Math.random() * (bgH * 0.18) / 4) * 4;
        oc.fillStyle = Math.random() < 0.5 ? '#ffe8a0' : '#fff8d0';
        oc.fillRect(sx, sy, Math.random() < 0.3 ? 4 : 2, Math.random() < 0.3 ? 4 : 2);
      }

      bgCache = off;
    }

    // Sun
    let sunAngle = 0;
    function drawSun() {
      const cx = Math.floor(W() * 0.72 / 4) * 4;
      const cy = Math.floor(H() * 0.20 / 4) * 4;
      const r = 32; const pz = 4;

      // Glow aura
      ctx.save();
      const grad = ctx.createRadialGradient(cx, cy, r, cx, cy, r * 3.5);
      grad.addColorStop(0, 'rgba(255,220,80,0.35)');
      grad.addColorStop(1, 'rgba(255,100,0,0)');
      ctx.fillStyle = grad;
      ctx.fillRect(cx - r * 4, cy - r * 4, r * 8, r * 8);
      ctx.restore();

      for (let dy = -r; dy <= r; dy += pz) {
        for (let dx = -r; dx <= r; dx += pz) {
          if (dx * dx + dy * dy <= r * r) {
            ctx.fillStyle = (dx + dy) < -10 ? '#ffe840' : (dx + dy) < 6 ? '#fff060' : '#ffe040';
            ctx.fillRect(cx + dx, cy + dy, pz, pz);
          }
        }
      }
      for (let i = 0; i < 12; i++) {
        const a = (i / 12) * Math.PI * 2 + sunAngle;
        const len = i % 2 === 0 ? 20 : 14;
        ctx.strokeStyle = 'rgba(255,230,80,0.8)';
        ctx.lineWidth = i % 2 === 0 ? 3 : 2;
        ctx.beginPath();
        ctx.moveTo(cx + Math.cos(a) * (r + 5), cy + Math.sin(a) * (r + 5));
        ctx.lineTo(cx + Math.cos(a) * (r + 5 + len), cy + Math.sin(a) * (r + 5 + len));
        ctx.stroke();
      }
    }

    // Pixel cat (black & white) holding bouquet - center bottom
    function drawCat(t) {
      const pz = 5;
      const catW = 80;
      const catH = 110;
      const cx = Math.floor(W() / 2);
      const cy = groundY() - 10;

      // Gentle breathing bob
      const bob = Math.sin(t * 0.02) * 2;

      // --- BOUQUET first (behind cat) ---
      drawBouquet(cx - 10, cy - catH * 0.55 + bob, pz, t);

      // --- CAT BODY ---
      ctx.save();
      ctx.translate(cx, cy + bob);

      // Body (white belly)
      const bodyPixels = [
        // [col, row, color] relative to center bottom
        // Tail
        [-6, 0, '#222'], [- 7, -1, '#222'], [-8, -2, '#222'], [-8, -3, '#222'], [-7, -4, '#333'],
        // Feet
        [-3, 0, '#ddd'], [-2, 0, '#eee'], [-1, 0, '#ddd'], [0, 0, '#eee'], [1, 0, '#ddd'], [2, 0, '#eee'], [3, 0, '#ddd'],
        // Legs
        [-3, -1, '#222'], [-2, -1, '#eee'], [-1, -1, '#eee'], [0, -1, '#eee'], [1, -1, '#eee'], [2, -1, '#eee'], [3, -1, '#222'],
        [-3, -2, '#222'], [-2, -2, '#eee'], [-1, -2, '#eee'], [0, -2, '#eee'], [1, -2, '#eee'], [2, -2, '#eee'], [3, -2, '#222'],
        // Body lower
        [-4, -3, '#222'], [-3, -3, '#333'], [-2, -3, '#eee'], [-1, -3, '#eee'], [0, -3, '#eee'], [1, -3, '#eee'], [2, -3, '#333'], [3, -3, '#222'],
        [-4, -4, '#222'], [-3, -4, '#eee'], [-2, -4, '#eee'], [-1, -4, '#eee'], [0, -4, '#eee'], [1, -4, '#eee'], [2, -4, '#333'], [3, -4, '#222'],
        [-4, -5, '#222'], [-3, -5, '#eee'], [-2, -5, '#eee'], [-1, -5, '#eee'], [0, -5, '#eee'], [1, -5, '#eee'], [2, -5, '#222'], [3, -5, '#222'],
        // Body upper (more black on top/back)
        [-4, -6, '#222'], [-3, -6, '#222'], [-2, -6, '#ddd'], [-1, -6, '#eee'], [0, -6, '#eee'], [1, -6, '#222'], [2, -6, '#222'],
        [-4, -7, '#222'], [-3, -7, '#222'], [-2, -7, '#ccc'], [-1, -7, '#ddd'], [0, -7, '#222'], [1, -7, '#222'],
        // Arms
        [-5, -4, '#222'], [-5, -5, '#222'], [-5, -6, '#222'],
        [3, -4, '#222'], [4, -5, '#222'], [4, -6, '#222'], // right arm holds bouquet
        // Neck
        [-1, -8, '#eee'], [0, -8, '#eee'], [1, -8, '#222'],
        // Head
        [-4, -9, '#222'], [-3, -9, '#222'], [-2, -9, '#222'], [-1, -9, '#eee'], [0, -9, '#eee'], [1, -9, '#222'], [2, -9, '#222'],
        [-4, -10, '#222'], [-3, -10, '#222'], [-2, -10, '#ddd'], [-1, -10, '#eee'], [0, -10, '#eee'], [1, -10, '#222'], [2, -10, '#222'],
        [-4, -11, '#111'], [-3, -11, '#222'], [-2, -11, '#333'], [-1, -11, '#222'], [0, -11, '#eee'], [1, -11, '#222'], [2, -11, '#111'],
        [-3, -12, '#111'], [-2, -12, '#222'], [-1, -12, '#222'], [0, -12, '#eee'], [1, -12, '#222'], [2, -12, '#111'],
        // Ears
        [-4, -12, '#222'], [-4, -13, '#222'], [-3, -13, '#333'],
        [2, -12, '#222'], [2, -13, '#222'], [3, -13, '#111'],
        // Eyes (green)
        [-2, -11, '#33cc44'], [1, -11, '#33cc44'],
        [-2, -10, '#111'], [1, -10, '#111'],
        // Nose
        [-1, -10, '#ff9999'], [0, -10, '#ff9999'],
        // White patch on face
        [-1, -12, '#eee'], [0, -12, '#eee'],
      ];

      bodyPixels.forEach(([col, row, color]) => {
        ctx.fillStyle = color;
        ctx.fillRect(col * pz - pz / 2, row * pz, pz, pz);
      });

      ctx.restore();
    }

    function drawBouquet(cx, cy, pz, t) {
      // Stems
      const stems = [[-2, 0], [-1, -1], [0, -2], [1, -1], [2, 0], [0, -3], [-3, 1], [3, 1]];
      stems.forEach(([dx, dy]) => {
        ctx.fillStyle = '#2d6e1e';
        ctx.fillRect(cx + dx * pz - 1, cy + dy * pz, 3, pz * 3);
      });

      // Sunflower heads in bouquet
      const flowers = [
        { ox: -20, oy: -50, r: 14, speed: 0.012 },
        { ox: 10, oy: -60, r: 16, speed: 0.009 },
        { ox: -5, oy: -75, r: 12, speed: 0.015 },
        { ox: 25, oy: -45, r: 11, speed: 0.011 },
        { ox: -30, oy: -40, r: 10, speed: 0.013 },
      ];

      flowers.forEach(f => {
        const fpz = 3;
        const fangle = t * f.speed;
        ctx.save();
        ctx.translate(cx + f.ox, cy + f.oy);
        ctx.rotate(fangle);
        // Petals
        const numP = 12;
        for (let i = 0; i < numP; i++) {
          const a = (i / numP) * Math.PI * 2;
          const px2 = Math.cos(a) * f.r * 0.9;
          const py2 = Math.sin(a) * f.r * 0.9;
          ctx.save();
          ctx.translate(px2, py2);
          ctx.rotate(a + Math.PI / 2);
          ctx.fillStyle = i % 2 === 0 ? '#f5c800' : '#e8a800';
          const pw = fpz * 2.5, ph = fpz * 4.5;
          for (let dy2 = -ph / 2; dy2 <= ph / 2; dy2 += fpz) {
            for (let dx2 = -pw / 2; dx2 <= pw / 2; dx2 += fpz) {
              if ((dx2 / pw * 2) ** 2 * 0.7 + (dy2 / ph * 2) ** 2 <= 1) ctx.fillRect(Math.round(dx2 / fpz) * fpz, Math.round(dy2 / fpz) * fpz, fpz, fpz);
            }
          }
          ctx.restore();
        }
        // Core
        const cr2 = f.r * 0.42;
        for (let dy2 = -cr2; dy2 <= cr2; dy2 += fpz) {
          for (let dx2 = -cr2; dx2 <= cr2; dx2 += fpz) {
            if (dx2 * dx2 + dy2 * dy2 <= cr2 * cr2) {
              ctx.fillStyle = (dx2 + dy2) < -3 ? '#4a2008' : '#6a3010';
              ctx.fillRect(Math.round(dx2 / fpz) * fpz, Math.round(dy2 / fpz) * fpz, fpz, fpz);
            }
          }
        }
        ctx.restore();
      });

      // Leaves wrapping
      [[- 15, - 20, '#3a8020'], [10, -15, '#2e7018'], [- 25, -5, '#4a9028'], [20, -8, '#3a8020']].forEach(([lx, ly, lc]) => {
        ctx.fillStyle = lc;
        ctx.fillRect(cx + lx, cy + ly, 16, 8);
        ctx.fillRect(cx + lx + 4, cy + ly - 4, 8, 6);
      });

      // Ribbon
      ctx.fillStyle = '#e83060';
      for (let i = -3; i <= 3; i++) {
        ctx.fillRect(cx + i * 3, cy + 6, 3, 10);
      }
      ctx.fillStyle = '#ff6090';
      ctx.fillRect(cx - 6, cy + 4, 5, 5);
      ctx.fillRect(cx + 2, cy + 4, 5, 5);
    }

    class Petal {
      constructor() { this.reset(true); }
      reset(init = false) {
        this.x = Math.random() * W();
        this.y = init ? Math.random() * H() : -10 - Math.random() * 60;
        this.size = 4 + Math.random() * 7;
        this.vx = (Math.random() - 0.5) * 1.0;
        this.vy = 0.7 + Math.random() * 1.2;
        this.rot = Math.random() * Math.PI * 2;
        this.rotSpeed = (Math.random() - 0.5) * 0.07;
        this.opacity = 0.65 + Math.random() * 0.35;
        this.color = ['#f5c800', '#e8a000', '#ffdd44', '#f0b800'][Math.floor(Math.random() * 4)];
        this.wobble = Math.random() * Math.PI * 2;
        this.wobbleSpeed = 0.025 + Math.random() * 0.04;
      }
      update() {
        this.wobble += this.wobbleSpeed;
        this.x += this.vx + Math.sin(this.wobble) * 0.5;
        this.y += this.vy;
        this.rot += this.rotSpeed;
        if (this.y > H() + 20) this.reset();
      }
      draw() {
        ctx.save();
        ctx.globalAlpha = this.opacity;
        ctx.translate(this.x, this.y);
        ctx.rotate(this.rot);
        ctx.fillStyle = this.color;
        const s = this.size, fpz = Math.max(2, Math.round(s / 3));
        for (let dy = -s / 2; dy <= s / 2; dy += fpz) {
          for (let dx = -s; dx <= s; dx += fpz) {
            if ((dx / s) ** 2 * 0.6 + (dy / (s / 2)) ** 2 <= 1) ctx.fillRect(Math.round(dx / fpz) * fpz, Math.round(dy / fpz) * fpz, fpz, fpz);
          }
        }
        ctx.restore();
        ctx.globalAlpha = 1;
      }
    }

    // Background sunflowers field
    class BgSunflower {
      constructor(x, scale) {
        this.x = x;
        this.scale = scale;
        this.stemH = (70 + Math.random() * 55) * scale;
        this.sway = Math.random() * Math.PI * 2;
        this.swaySpeed = 0.010 + Math.random() * 0.008;
        this.swayDir = 1;
        this.swayAmt = 0;
        this.swayMax = 0.06;
        this.headAngle = Math.random() * Math.PI * 2;
        this.headSpeed = 0.007 + Math.random() * 0.007;
        this.baseAngle = (Math.random() - 0.5) * 0.12;
      }
      update() {
        this.headAngle += this.headSpeed;
        this.swayAmt += this.swaySpeed * this.swayDir;
        if (Math.abs(this.swayAmt) > this.swayMax) this.swayDir *= -1;
      }
      draw() {
        const pz = Math.max(2, Math.round(3 * this.scale));
        const gY = groundY();
        const totalSway = this.baseAngle + this.swayAmt;
        const headX = this.x + Math.sin(totalSway) * this.stemH * 0.28;
        const headY = gY - this.stemH;

        // Stem
        ctx.strokeStyle = '#3a7030';
        ctx.lineWidth = pz * 1.6;
        ctx.beginPath();
        ctx.moveTo(this.x, gY);
        ctx.quadraticCurveTo(this.x + Math.sin(totalSway) * 15, headY + this.stemH * 0.5, headX, headY);
        ctx.stroke();

        // Leaf
        const midY = gY - this.stemH * 0.52;
        ctx.fillStyle = '#4a8c3a';
        const lsz = pz * 3.5;
        ctx.save(); ctx.translate(this.x, midY); ctx.rotate(totalSway + 0.5);
        ctx.fillRect(-lsz * 0.5, -lsz * 0.22, lsz, lsz * 0.44); ctx.restore();

        // Head
        const headR = (24 + 4) * this.scale;
        const numP = 14;
        ctx.save();
        ctx.translate(headX, headY);
        ctx.rotate(this.headAngle);
        for (let i = 0; i < numP; i++) {
          const a = (i / numP) * Math.PI * 2;
          const px2 = Math.cos(a) * headR * 0.88, py2 = Math.sin(a) * headR * 0.88;
          ctx.save(); ctx.translate(px2, py2); ctx.rotate(a + Math.PI / 2);
          ctx.fillStyle = i % 2 === 0 ? '#f5c800' : '#e0b000';
          const pw = pz * 3, ph = pz * 5.5;
          for (let dy = -ph / 2; dy <= ph / 2; dy += pz) {
            for (let dx = -pw / 2; dx <= pw / 2; dx += pz) {
              if ((dx / pw * 2) ** 2 * 0.8 + (dy / ph * 2) ** 2 <= 1) ctx.fillRect(Math.round(dx / pz) * pz, Math.round(dy / pz) * pz, pz, pz);
            }
          }
          ctx.restore();
        }
        const cr = 14 * this.scale;
        for (let dy = -cr; dy <= cr; dy += pz) {
          for (let dx = -cr; dx <= cr; dx += pz) {
            if (dx * dx + dy * dy <= cr * cr) {
              ctx.fillStyle = (dx + dy) < -3 ? '#4a2008' : '#6a3210';
              ctx.fillRect(Math.round(dx / pz) * pz, Math.round(dy / pz) * pz, pz, pz);
            }
          }
        }
        ctx.restore();
      }
    }

    let sunflowers = [], petals = [];

    function initScene() {
      sunflowers = [];
      const w = W();
      const count = Math.floor(w / 75) + 3;
      const positions = [];
      for (let i = 0; i < count + 5; i++) {
        positions.push({
          x: 30 + Math.random() * (w - 60),
          scale: 0.55 + Math.random() * 0.72
        });
      }
      positions.sort((a, b) => a.scale - b.scale);
      // Skip center area for cat
      positions.forEach(p => {
        if (Math.abs(p.x - W() / 2) > 120 || p.scale < 0.7) {
          sunflowers.push(new BgSunflower(p.x, p.scale));
        }
      });

      petals = [];
      for (let i = 0; i < 40; i++) petals.push(new Petal());
    }

    initScene();

    let t = 0;
    function loop() {
      t++;
      renderBg();
      ctx.clearRect(0, 0, W(), H());
      if (bgCache) ctx.drawImage(bgCache, 0, 0);

      sunAngle += 0.004;
      drawSun();

      // Warm atmospheric haze near horizon
      const gY = groundY();
      ctx.save();
      const haze = ctx.createLinearGradient(0, gY - 60, 0, gY + 20);
      haze.addColorStop(0, 'rgba(255,140,20,0)');
      haze.addColorStop(1, 'rgba(255,140,20,0.18)');
      ctx.fillStyle = haze;
      ctx.fillRect(0, gY - 60, W(), 80);
      ctx.restore();

      sunflowers.forEach(sf => { sf.update(); sf.draw(); });
      drawCat(t);
      petals.forEach(p => { p.update(); p.draw(); });

      requestAnimationFrame(loop);
    }
    loop();

    // Audio
    const audio = document.getElementById('audio');
    const playBtn = document.getElementById('playBtn');
    const volSlider = document.getElementById('volumeSlider');
    const nowPlaying = document.getElementById('nowPlaying');
    const fileInput = document.getElementById('fileInput');
    let playing = false;
    audio.volume = 0.7;

    audio.addEventListener('canplaythrough', () => {
      if (!playing) { audio.play(); playBtn.textContent = '⏸'; playing = true; }
    });

    playBtn.addEventListener('click', () => {
      if (!audio.src) return;
      if (playing) { audio.pause(); playBtn.textContent = '▶'; playing = false; }
      else { audio.play(); playBtn.textContent = '⏸'; playing = true; }
    });

    volSlider.addEventListener('input', () => { audio.volume = parseFloat(volSlider.value); });

    fileInput.addEventListener('change', (e) => {
      const file = e.target.files[0];
      if (!file) return;
      audio.src = URL.createObjectURL(file);
      nowPlaying.textContent = file.name.replace(/\.[^.]+$/, '').substring(0, 26);
      audio.play(); playBtn.textContent = '⏸'; playing = true;
    });
  </script>
</body>

</html>
